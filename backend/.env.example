# ==============================================
# LLM 大模型配置
# ==============================================
# LLM类型：ALIYUN(阿里云百炼) | OLLAMA(本地模型) | DEEPSEEK(DeepSeek API)
LLM_TYPE=DEEPSEEK

# ==============================================
# DeepSeek 配置（仅 LLM_TYPE=DEEPSEEK 时生效）
# ==============================================
# DeepSeek API Key（格式：sk-xxxx）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key
# DeepSeek API 地址（默认为官方地址，可按需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek 聊天模型名称（deepseek-v4-flash）
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ==============================================
# Ollama 配置（仅 LLM_TYPE=OLLAMA 时生效）
# ==============================================
# Ollama 服务地址（本地运行Ollama时，默认为该地址）
OLLAMA_BASE_URL=http://localhost:11434
# Ollama 聊天模型（需提前 ollama pull 下载）
OLLAMA_MODEL_NAME=qwen3.5:0.8b

# ==============================================
# 阿里云百炼配置（仅 LLM_TYPE=ALIYUN 时生效），可能产生费用，注意控制用量
# ==============================================
# 阿里云 API Key（格式：sk-xxxx）
# 申请地址：https://dashscope.console.aliyun.com/
ALIYUN_ACCESS_KEY_SECRET=your_api_key
# 阿里云 API 地址
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云聊天模型名称
CHAT_MODEL_NAME=qwen3-max

# ==============================================
# 向量嵌入模型配置
# ==============================================
# 嵌入模型类型：OLLAMA | ALIYUN
EMBED_MODEL_TYPE=OLLAMA
# Ollama 嵌入模型（需提前下载），当EMBED_MODEL_TYPE=OLLAMA时使用
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
# 阿里云嵌入模型（当EMBED_MODEL_TYPE=ALIYUN时使用），需确保阿里云百炼平台有该模型且账户余额充足
ALIYUN_EMBED_MODEL_NAME=qwen3-embedding

# ==============================================
# 多模态视觉模型配置（用于PDF多模态图片描述）
# ==============================================
# 视觉模型类型：ALIYUN | OLLAMA；为空则沿用 LLM_TYPE
VISION_MODEL_TYPE=
# 阿里云视觉模型名称（当VISION_MODEL_TYPE=ALIYUN时使用），qwen3-max 已支持多模态
VISION_CHAT_MODEL_NAME=qwen3-max
# Ollama视觉模型名称（当VISION_MODEL_TYPE=OLLAMA时使用），需 ollama pull 下载
VISION_OLLAMA_MODEL_NAME=qwen-vl:7b

# ==============================================
# 视觉模型批处理优化配置（降低API调用次数和延迟）
# ==============================================
# 每批页数：将多页合并到一次视觉API调用（默认5，越大越省token但描述粒度可能下降）
VISION_BATCH_SIZE=5
# 是否启用感知哈希去重：相似页面只描述一次，结果共享（对PPT/模板类PDF效果显著）
VISION_DEDUP_ENABLED=true
# 感知哈希距离阈值（0-64，越小越严格）：两页哈希距离≤此值视为相似
VISION_DEDUP_THRESHOLD=10
# 批量处理时使用1x低分辨率代替2x（节省token和传输体积）
VISION_BATCH_LOW_RES=true

# ==============================================
# 重排序模型配置
# ==============================================
# 重排序模型本地路径（自动从魔搭社区下载）
RERANKER_MODEL_PATH=D:\Hugging_Face\models\Qwen3-Reranker-0.6B

# ==============================================
# 数据库配置
# ==============================================
# MySQL 配置
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chat_history

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==============================================
# 限流配置
# ==============================================
# 全局限流开关：设为 false 可禁用所有路由上的 rate_limit 依赖
# 开发调试阶段建议设为 false，生产环境建议设为 true 并配合具体阈值
RATE_LIMIT_ENABLED=false

# Django API 地址，用户服务地址，用于调用用户服务的API
DJANGO_API_URL=http://127.0.0.1:8001

# LangSmith 调试追踪
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=my-fastapi-langchain-project

# ==============================================
# JWT 身份验证配置
# ==============================================
SECRET_KEY=LaZuvBETFfy_w0lbVjjhvMejFKxj1EcB0FmgJ5lEOWg
# 注意：SECRET_KEY 必须和 DjangoUserService/.env 中的 JWT_SECRET_KEY 保持一致，否则 FastAPI 无法验证 Django 签发的 JWT
ALGORITHM=HS256
# 绕过系统代理，直连本地服务（Ollama、Redis、MySQL等）
NO_PROXY=localhost,127.0.0.1,::1