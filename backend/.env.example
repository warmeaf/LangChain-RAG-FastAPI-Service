# ==============================================
# LLM 大模型配置
# ==============================================
# LLM类型：ALIYUN(阿里云百炼) | DEEPSEEK(DeepSeek API)
LLM_TYPE=DEEPSEEK

# ==============================================
# DeepSeek 配置（仅 LLM_TYPE=DEEPSEEK 时生效）
# ==============================================
# DeepSeek API Key（格式：sk-xxxx）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key
# DeepSeek API 地址（默认为官方地址，可按需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek 聊天模型名称（deepseek-v4-flash）
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ==============================================
# 阿里云百炼配置（仅 LLM_TYPE=ALIYUN 时生效）
# ==============================================
# 阿里云 API Key（格式：sk-xxxx）
# 申请地址：https://dashscope.console.aliyun.com/
ALIYUN_ACCESS_KEY_SECRET=your_api_key
# 阿里云 API 地址
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云聊天模型名称
CHAT_MODEL_NAME=qwen3-max

# ==============================================
# 向量嵌入模型配置
# ==============================================
# 本地 SentenceTransformer 模型 (HuggingFace)
EMBED_MODEL_NAME=BAAI/bge-large-zh
IMAGE_EMBED_MODEL_NAME=openai/clip-vit-base-patch32

# HuggingFace 模型缓存目录（首次启动自动下载，约3GB）
# 示例：放在 backend/.cache/huggingface 下，避免占用用户主目录
# HF_HOME=.cache/huggingface
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ==============================================
# 多模态视觉模型配置（用于PDF多模态图片描述）
# ==============================================
# 视觉模型类型：ALIYUN；为空则沿用 LLM_TYPE
VISION_MODEL_TYPE=
# 阿里云视觉模型名称（当VISION_MODEL_TYPE=ALIYUN时使用）
VISION_CHAT_MODEL_NAME=qwen3-max

# ==============================================
# 视觉模型批处理优化配置
# ==============================================
VISION_BATCH_SIZE=5
VISION_DEDUP_ENABLED=true
VISION_DEDUP_THRESHOLD=10
VISION_BATCH_LOW_RES=true

# ==============================================
# 重排序模型配置
# ==============================================
# 默认使用 BAAI/bge-reranker-large，可在此覆盖
# RERANKER_MODEL_NAME=BAAI/bge-reranker-large

# ==============================================
# 数据库配置
# ==============================================
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chat_history

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=3

# ==============================================
# 限流配置
# ==============================================
RATE_LIMIT_ENABLED=false

# Django API 地址
DJANGO_API_URL=http://127.0.0.1:8001

# LangSmith 调试追踪
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=my-fastapi-langchain-project

# ==============================================
# JWT 身份验证配置
# ==============================================
SECRET_KEY=your_secret_key_here
# 注意：SECRET_KEY 必须和 DjangoUserService/.env 中的 JWT_SECRET_KEY 保持一致
ALGORITHM=HS256

# ==============================================
# Milvus 向量数据库配置
# ==============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
