{
  "name": "xwzx-news",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "biome check",
    "fix": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "typecheck": "vue-tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
